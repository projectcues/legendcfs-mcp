# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Security — set this in production to protect the /sse and /message endpoints
MCP_AUTH_TOKEN=your-secret-bearer-token

# VideoSDK (optional — falls back to mock if missing)
VIDEOSDK_API_KEY=
VIDEOSDK_SECRET=
VIDEOSDK_TEMPLATE_URL=https://mcp.legendcfs.com/index.html

# Whitepages (required for query_whitepages tool)
WHITEPAGES_API_KEY=

# Server (optional)
PORT=3000
